# Wajib diawali VITE_ agar Vite mengekspos ke browser.
# Set 3 variabel ini di Vercel → Project Settings → Environment Variables
# (centang Production, Preview, Development) lalu klik Redeploy.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key
VITE_SUPABASE_PROJECT_ID=your_supabase_project_ref
