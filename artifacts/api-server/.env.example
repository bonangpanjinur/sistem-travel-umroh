# ═══════════════════════════════════════════════════════════════════
#  Vinstour API Server — Environment Variables
#  Copy this file to .env at the REPO ROOT for local development.
#  For Railway/production: set these in Railway's Variables panel.
# ═══════════════════════════════════════════════════════════════════

# ─── REQUIRED ────────────────────────────────────────────────────────
# PostgreSQL connection string to Supabase (direct connection, NOT pooled)
# Format: postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres?sslmode=require
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require

# Server port (Railway sets this automatically — do NOT override on Railway)
PORT=3001

# Node environment
NODE_ENV=production

# JWT secret — use a long random string (min 32 chars). Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
APP_JWT_SECRET=change-me-to-a-long-random-secret-string

# URL of the deployed frontend (used for payment redirect URLs)
# Example: https://vinstour.vercel.app
FRONTEND_URL=https://your-vercel-app.vercel.app

# ─── SUPABASE (for sitemap generation & integrations health check) ───
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGci...your-anon-key

# ─── WHATSAPP — Fonnte ───────────────────────────────────────────────
# Token API dari https://fonnte.com — jika dikosongkan, admin bisa isi via UI
FONNTE_TOKEN=

# ─── EMAIL — SMTP ────────────────────────────────────────────────────
# Gunakan Gmail App Password, Brevo, Resend, atau SMTP lainnya
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=yourname@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=Vinstour Travel <yourname@gmail.com>

# ─── PAYMENT — Midtrans ──────────────────────────────────────────────
# Dapatkan kunci di https://dashboard.midtrans.com → Settings → Access Keys
MIDTRANS_SERVER_KEY=SB-Mid-server-...
MIDTRANS_CLIENT_KEY=SB-Mid-client-...
# "sandbox" untuk testing, "production" untuk live
MIDTRANS_ENV=sandbox

# ─── PAYMENT — Xendit (opsional) ─────────────────────────────────────
XENDIT_SECRET_KEY=xnd_development_...
XENDIT_CALLBACK_TOKEN=
XENDIT_ENV=development

# ─── PUSH NOTIFICATIONS — Web Push / VAPID ───────────────────────────
# Generate dengan: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@yourdomain.com

# ─── AI / CHATBOT ────────────────────────────────────────────────────
# Google Gemini — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# OpenAI (opsional fallback)
OPENAI_API_KEY=

# ─── APP INFO ────────────────────────────────────────────────────────
APP_NAME=Vinstour Travel
APP_URL=https://your-railway-app.up.railway.app
LOG_LEVEL=info
